<Window x:Class="Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Launcher" Height="760" Width="1240" MinHeight="560" MinWidth="900"
        Background="#1b2838" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2f81f7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a94ff"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#39414d"/>
                                <Setter Property="Foreground" Value="#737d89"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#5ba32b"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" Padding="20,12"
                                BorderThickness="0,0,0,3" BorderBrush="Transparent" Cursor="Hand">
                            <ContentPresenter x:Name="hdr" ContentSource="Header"
                                              TextElement.FontSize="15" TextElement.FontWeight="Bold"
                                              TextElement.Foreground="#8f98a0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2f81f7"/>
                                <Setter TargetName="hdr" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hdr" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="Transparent" Padding="12,9" Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#232b36"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2a475e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Pastki status bar -->
        <Border DockPanel.Dock="Bottom" Background="#171a21" Padding="12,7">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="⟳ Katalogni yangilash" Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="12,5" FontSize="12"/>
                <TextBlock Text="{Binding LauncherStatus}" Foreground="#8f98a0"
                           VerticalAlignment="Center" Margin="14,0"/>
            </DockPanel>
        </Border>

        <TabControl Background="Transparent" BorderThickness="0" Padding="0">
            <!-- ============ KUTUBXONA ============ -->
            <TabItem Header="O'YINLAR KUTUBXONASI">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Chap: o'yinlar ro'yxati -->
                    <Border Grid.Column="0" Background="#171d25">
                        <ListBox ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="34" Height="44"
                                                ClipToBounds="True" CornerRadius="3" Background="#11151b">
                                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Game.Name}" Foreground="White"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ListStatusText}" Foreground="#8f98a0"
                                                       FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- O'ng: tanlangan o'yin detali (o'yin tanlanmagan bo'lsa yashirin) -->
                    <ContentControl Grid.Column="1" Content="{Binding SelectedGame}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <Trigger Property="Content" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="2*" MaxHeight="380"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Asosiy rasm (GitHub'dagi coverUrl) -->
                                    <Border Grid.Row="0" ClipToBounds="True" Background="#11151b">
                                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Tugmalar paneli -->
                                    <Border Grid.Row="1" Background="#22262e" Padding="18,14">
                                        <StackPanel>
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                    <Button Content="{Binding MainButtonLabel}" Command="{Binding MainCommand}"
                                                            Style="{StaticResource GreenButton}" MinWidth="170"/>
                                                    <Button Content="⬆ YANGILASH" Command="{Binding UpdateCommand}"
                                                            Style="{StaticResource PrimaryButton}" MinWidth="150" Margin="10,0,0,0"/>
                                                    <Button Content="✕" Command="{Binding CancelCommand}"
                                                            Visibility="{Binding CancelVisibility}"
                                                            Style="{StaticResource PrimaryButton}" Background="#aa3333"
                                                            Width="40" Margin="10,0,0,0"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VersionText}" Foreground="#c5cbd1" FontSize="13"/>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="#e8a33d" FontSize="12"
                                                               HorizontalAlignment="Right" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </DockPanel>

                                            <!-- Yangilash foiz bar -->
                                            <DockPanel Margin="0,12,0,0" Visibility="{Binding ProgressVisibility}">
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding ProgressText}"
                                                           Foreground="White" FontWeight="Bold" FontSize="13"
                                                           Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="44"/>
                                                <ProgressBar Height="10" Maximum="100"
                                                             Value="{Binding Progress, Mode=OneWay}"
                                                             IsIndeterminate="{Binding IsIndeterminate}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- O'yin haqida ma'lumot (GitHub'dagi description) -->
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="18,14">
                                            <TextBlock Text="{Binding Game.Name}" Foreground="White"
                                                       FontSize="20" FontWeight="Bold"/>
                                            <TextBlock Text="O'YIN HAQIDA" Foreground="#8f98a0" FontSize="11"
                                                       FontWeight="Bold" Margin="0,14,0,4"/>
                                            <TextBlock Text="{Binding Game.Description}" Foreground="#c5cbd1"
                                                       FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                            <TextBlock Text="SO'NGGI O'ZGARISHLAR" Foreground="#8f98a0" FontSize="11"
                                                       FontWeight="Bold" Margin="0,16,0,4"/>
                                            <TextBlock Text="{Binding Game.Changelog}" Foreground="#9aa0a6"
                                                       FontSize="12" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                                <Button Content="Papkani ochish" Command="{Binding OpenFolderCommand}"
                                                        Style="{StaticResource PrimaryButton}" Background="#39414d"
                                                        FontSize="11" Padding="10,5"/>
                                                <Button Content="O'chirish" Command="{Binding UninstallCommand}"
                                                        Style="{StaticResource PrimaryButton}" Background="#39414d"
                                                        FontSize="11" Padding="10,5" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Grid>
            </TabItem>

            <!-- ============ QO'LLANMA ============ -->
            <TabItem Header="QO'LLANMA">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,20" MaxWidth="760" HorizontalAlignment="Left">
                        <TextBlock Text="Launcher qanday ishlaydi?" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Foreground="#c5cbd1" FontSize="13" TextWrapping="Wrap" LineHeight="22" Margin="0,14,0,0">
                            <Run FontWeight="Bold" Foreground="White">1. O'rnatish.</Run>
                            <Run>Chap ro'yxatdan o'yinni tanlab, O'RNATISH tugmasini bosing. O'yin yuklab olinadi, fayl butunligi tekshiriladi va o'rnatiladi.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="White">2. Yangilash.</Run>
                            <Run>Yangi versiya chiqqanda YANGILASH tugmasi yonadi va ro'yxatda "Yangilanish bor!" yozuvi chiqadi. Yangilash paytida saqlangan o'yin ma'lumotlaringiz yo'qolmaydi.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="White">3. O'ynash.</Run>
                            <Run>O'YNASH tugmasi o'rnatilgan versiyani ishga tushiradi.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="White">4. O'chirish.</Run>
                            <Run>O'yin sahifasidagi "O'chirish" tugmasi faqat o'yin fayllarini o'chiradi — saqlangan ma'lumotlar (saves) kompyuterda qoladi va qayta o'rnatganda tiklanadi.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="White">Internet uzilsa nima bo'ladi?</Run>
                            <Run>Hech narsa buzilmaydi: yuklab olish tugamaguncha eski versiya joyida qoladi. Qaytadan YANGILASH bosing.</Run>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ SOZLAMALAR ============ -->
            <TabItem Header="SOZLAMALAR">
                <StackPanel Margin="28,20" MaxWidth="680" HorizontalAlignment="Left">
                    <TextBlock Text="Sozlamalar" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Katalog manzili (games.json):" Foreground="#c5cbd1" FontSize="13" Margin="0,18,0,6"/>
                    <TextBox Text="{Binding CatalogUrlInput, UpdateSourceTrigger=PropertyChanged}"
                             Background="#11151b" Foreground="White" BorderBrush="#39414d"
                             BorderThickness="1" Padding="9,7" FontSize="13" CaretBrush="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Saqlash" Command="{Binding SaveSettingsCommand}"
                                Style="{StaticResource PrimaryButton}" MinWidth="120"/>
                        <Button Content="Launcher papkasini ochish" Command="{Binding OpenRootCommand}"
                                Style="{StaticResource PrimaryButton}" Background="#39414d" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock Foreground="#8f98a0" FontSize="12" TextWrapping="Wrap" LineHeight="19" Margin="0,22,0,0">
                        O'yinlar Launcher.exe yonidagi Games papkasiga o'rnatiladi.
                        Saqlangan o'yin ma'lumotlari esa har o'yinning o'zining AppData papkasida turadi —
                        launcher ularga tegmaydi.
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
