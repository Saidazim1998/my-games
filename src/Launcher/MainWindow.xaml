<Window x:Class="Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Launcher" Height="720" Width="1100"
        Background="#1b2838" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2f81f7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a94ff"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3a4654"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#171a21" Padding="16,10">
            <DockPanel>
                <TextBlock Text="O'YINLAR KUTUBXONASI" Foreground="White" FontSize="18"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="⟳ Yangilash" Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="14,6" HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding LauncherStatus}" Foreground="#9aa0a6"
                           VerticalAlignment="Center" Margin="16,0"/>
            </DockPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Games}" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Margin="10" Background="#2a2e35" CornerRadius="8">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="O'chirish" Command="{Binding UninstallCommand}"/>
                                    <MenuItem Header="Papkani ochish" Command="{Binding OpenFolderCommand}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel>
                                <Border Height="280" ClipToBounds="True" CornerRadius="8,8,0,0" Background="#22262c">
                                    <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Margin="12,10,12,12">
                                    <TextBlock Text="{Binding Game.Name}" FontSize="15" FontWeight="Bold"
                                               Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding VersionText}" Foreground="#9aa0a6"
                                               FontSize="11" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding Game.Changelog}" Foreground="#7f868d" FontSize="11"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Game.Changelog}"
                                               Margin="0,2,0,0"/>
                                    <ProgressBar Height="6" Margin="0,8,0,0" Maximum="100"
                                                 Value="{Binding Progress, Mode=OneWay}"
                                                 IsIndeterminate="{Binding IsIndeterminate}"
                                                 Visibility="{Binding ProgressVisibility}"/>
                                    <TextBlock Text="{Binding StatusText}" Foreground="#e8a33d" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="{Binding ActionLabel}" Command="{Binding PrimaryCommand}"
                                                Style="{StaticResource PrimaryButton}"/>
                                        <Button Grid.Column="1" Content="✕" Command="{Binding CancelCommand}"
                                                Visibility="{Binding CancelVisibility}"
                                                Style="{StaticResource PrimaryButton}" Background="#aa3333"
                                                Width="34" Margin="6,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
